  ctx.fillStyle='rgba(255,255,255,0.7)';
  ctx.fillText(zone.theme,canvas.width/2,500);
  ctx.font='bold 40px "Inter", sans-serif';
  ctx.fillStyle='#FFD700';
  ctx.fillText(`${zone.levels.length} Levels Mastered`,canvas.width/2,600);
