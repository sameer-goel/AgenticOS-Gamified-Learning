const ALL_STORIES = [];
ZONES.forEach(z => z.levels.forEach(l => { if(l.story) ALL_STORIES.push({...l.story, levelId:l.id, zoneName:z.name, zoneColor:z.color}); }));

// ===== STATE =====
let state = {
  xp:0, completedLevels:[], badges:[], storiesUnlocked:[], quizResults:{},
  currentZone:1, currentLevel:null, streak:0, maxStreak:0, soundOn:false,
  startTime:Date.now(), speedBonuses:0, levelStartTime:null, leaderboard:{runs:[],levelTimes:{},zoneCompletionTimes:{}}
};

function loadState(){
  try{
    const s = localStorage.getItem('openclaw_state');
    if(s){ const p=JSON.parse(s); Object.assign(state,p); }
    if(!state.leaderboard) state.leaderboard={runs:[],levelTimes:{},zoneCompletionTimes:{}};
  }catch(e){}
}
function saveState(){
  try{ localStorage.setItem('openclaw_state',JSON.stringify(state)); }catch(e){}
}
function resetState(){
  if(!confirm('Reset ALL progress? This cannot be undone.')) return;
  state={xp:0,completedLevels:[],badges:[],storiesUnlocked:[],quizResults:{},currentZone:1,currentLevel:null,streak:0,maxStreak:0,soundOn:state.soundOn,startTime:Date.now(),speedBonuses:0,levelStartTime:null,leaderboard:{runs:[],levelTimes:{},zoneCompletionTimes:{}}};
  saveState(); init();
}

// ===== SOUND ENGINE =====
let audioCtx = null;
function getAudioCtx(){ if(!audioCtx) audioCtx=new (window.AudioContext||window.webkitAudioContext)(); return audioCtx; }

// Helper: play a note with specific waveform, frequency, duration, and gain
function _note(ctx,freq,startT,dur,vol,wave){
  var o=ctx.createOscillator(),g=ctx.createGain();
  o.type=wave||'sine';o.frequency.setValueAtTime(freq,startT);
  g.gain.setValueAtTime(vol,startT);
  g.gain.setValueAtTime(vol,startT+dur*0.6);
  g.gain.exponentialRampToValueAtTime(0.001,startT+dur);
  o.connect(g);g.connect(ctx.destination);
  o.start(startT);o.stop(startT+dur);
}

// Helper: play a chord (array of frequencies)
function _chord(ctx,freqs,startT,dur,vol,wave){
  freqs.forEach(function(f){_note(ctx,f,startT,dur,vol/(freqs.length*0.6),wave||'sine');});
}

// Helper: noise burst for percussive sparkle effects
function _noise(ctx,startT,dur,vol){
  var bufSize=Math.max(1,Math.floor(ctx.sampleRate*dur));
  var buf=ctx.createBuffer(1,bufSize,ctx.sampleRate);
  var data=buf.getChannelData(0);
  for(var i=0;i<bufSize;i++) data[i]=(Math.random()*2-1);
  var src=ctx.createBufferSource();src.buffer=buf;
  var filt=ctx.createBiquadFilter();filt.type='bandpass';filt.frequency.value=1000;filt.Q.value=0.5;
  var g=ctx.createGain();g.gain.setValueAtTime(vol,startT);g.gain.exponentialRampToValueAtTime(0.001,startT+dur);
  src.connect(filt);filt.connect(g);g.connect(ctx.destination);
  src.start(startT);src.stop(startT+dur);
}

function playSound(type){
  if(!state.soundOn) return;
  try{
    var ctx=getAudioCtx(), t=ctx.currentTime;

    if(type==='click'){
      // Subtle UI click
      _note(ctx,1800,t,0.04,0.08,'sine');
      _note(ctx,2400,t+0.015,0.03,0.05,'sine');
    }
    else if(type==='xp'){
      // XP gain ‚Äî bright ascending sparkle with harmonics
      _note(ctx,880,t,0.12,0.1,'sine');
      _note(ctx,1320,t+0.04,0.1,0.08,'sine');
      _note(ctx,1760,t+0.08,0.15,0.07,'triangle');
      _noise(ctx,t,0.06,0.02);
    }
    else if(type==='success'){
      // Correct answer ‚Äî cheerful ascending major triad arpeggio + sparkle
      _note(ctx,523.25,t,0.18,0.12,'sine');
      _note(ctx,659.25,t+0.1,0.18,0.12,'sine');
      _note(ctx,783.99,t+0.2,0.22,0.12,'sine');
      _note(ctx,1046.5,t+0.3,0.3,0.1,'triangle');
      _note(ctx,1568,t+0.35,0.2,0.04,'sine');
      _noise(ctx,t+0.3,0.08,0.015);
    }
    else if(type==='wrong'){
      // Wrong answer ‚Äî dissonant descending buzz
      _note(ctx,330,t,0.15,0.08,'sawtooth');
      _note(ctx,277,t+0.08,0.15,0.07,'sawtooth');
      _note(ctx,220,t+0.16,0.2,0.06,'sawtooth');
      _noise(ctx,t,0.12,0.03);
    }
    else if(type==='badge'){
      // Badge earned ‚Äî triumphant fanfare with chords
      _chord(ctx,[523.25,659.25,783.99],t,0.25,0.15,'sine');
      _chord(ctx,[587.33,739.99,880],t+0.2,0.25,0.15,'sine');
      _chord(ctx,[659.25,830.61,987.77],t+0.4,0.25,0.15,'sine');
      _note(ctx,1046.5,t+0.55,0.5,0.12,'triangle');
      _note(ctx,1318.5,t+0.6,0.5,0.08,'triangle');
      _note(ctx,1568,t+0.65,0.5,0.06,'sine');
      _noise(ctx,t+0.55,0.1,0.02);
    }
    else if(type==='zone'){
      // Zone complete ‚Äî epic ascending fanfare with full chords
      _chord(ctx,[261.63,329.63,392],t,0.2,0.12,'sine');
      _chord(ctx,[329.63,415.30,493.88],t+0.18,0.2,0.12,'sine');
      _chord(ctx,[392,493.88,587.33],t+0.36,0.2,0.12,'sine');
      _chord(ctx,[523.25,659.25,783.99],t+0.54,0.35,0.14,'sine');
      _note(ctx,1046.5,t+0.7,0.5,0.1,'triangle');
      _note(ctx,1318.5,t+0.75,0.5,0.08,'triangle');
      _note(ctx,1568,t+0.8,0.5,0.06,'sine');
      _note(ctx,2093,t+0.85,0.6,0.04,'sine');
      _noise(ctx,t+0.54,0.15,0.025);
      _noise(ctx,t+0.8,0.1,0.015);
    }
    else if(type==='streak'){
      // Streak bonus ‚Äî rapid ascending ping cascade
      _note(ctx,660,t,0.1,0.08,'sine');
      _note(ctx,880,t+0.06,0.1,0.08,'sine');
      _note(ctx,1100,t+0.12,0.1,0.08,'triangle');
      _note(ctx,1320,t+0.18,0.12,0.07,'triangle');
      _note(ctx,1760,t+0.24,0.15,0.06,'sine');
    }
    else if(type==='unlock'){
      // New zone unlock ‚Äî magical ascending whoosh
      _note(ctx,440,t,0.15,0.06,'sine');
      _note(ctx,554,t+0.08,0.15,0.06,'sine');
      _note(ctx,659,t+0.16,0.15,0.07,'triangle');
      _note(ctx,880,t+0.24,0.2,0.08,'triangle');
      _note(ctx,1100,t+0.32,0.2,0.06,'sine');
      _noise(ctx,t+0.2,0.15,0.02);
    }
    else if(type==='drag'){
      // Drag pickup ‚Äî soft pop
      _note(ctx,600,t,0.05,0.06,'sine');
      _note(ctx,900,t+0.02,0.04,0.04,'sine');
    }
    else if(type==='drop'){
      // Drop onto target ‚Äî satisfying thunk
      _note(ctx,400,t,0.08,0.07,'sine');
      _note(ctx,600,t+0.02,0.06,0.05,'triangle');
      _noise(ctx,t,0.04,0.02);
    }
    else if(type==='levelcomplete'){
      // Level complete ‚Äî warm completion jingle
      _note(ctx,523.25,t,0.15,0.1,'sine');
      _note(ctx,587.33,t+0.12,0.15,0.1,'sine');
      _note(ctx,659.25,t+0.24,0.15,0.1,'sine');
      _note(ctx,783.99,t+0.36,0.25,0.12,'sine');
      _chord(ctx,[523.25,659.25,783.99],t+0.48,0.4,0.12,'triangle');
      _noise(ctx,t+0.48,0.08,0.015);
    }
  }catch(e){}
}

// ===== HELPERS =====
function getRank(){
  let r=RANKS[0];
  for(const rank of RANKS){ if(state.xp>=rank.xp) r=rank; }
  return r;
}
function getNextRank(){
  for(let i=0;i<RANKS.length;i++){ if(state.xp<RANKS[i].xp) return RANKS[i]; }
  return null;
}
function isLevelCompleted(id){ return state.completedLevels.includes(id); }
function isZoneCompleted(zoneId){
  const z=ZONES.find(z=>z.id===zoneId);
  return z && z.levels.every(l=>isLevelCompleted(l.id));
}
function isZoneUnlocked(zoneId){
  if(zoneId===1) return true;
  return isZoneCompleted(zoneId-1);
}
function isLevelUnlocked(levelId){
  const parts=levelId.split('.');
  const zoneId=parseInt(parts[0]);
  const levelNum=parseInt(parts[1]);
  if(!isZoneUnlocked(zoneId)) return false;
  if(levelNum===1) return true;
  const prevId=zoneId+'.'+(levelNum-1);
  return isLevelCompleted(prevId);
}
function getZoneColor(zoneId){
  const z=ZONES.find(z=>z.id===zoneId);
  return z?z.color:'#00F0FF';
}
function getZoneForLevel(levelId){
  return ZONES.find(z=>z.levels.some(l=>l.id===levelId));
}
function announce(msg){
  const el=document.getElementById('aria-live');
  el.textContent=msg;
  setTimeout(()=>el.textContent='',3000);
}

// ===== XP SYSTEM =====
function awardXP(amount, sourceEl){
  state.xp+=amount;
  playSound('xp');
  updateTopBar();
  saveState();
  // Float animation
  const float=document.createElement('div');
  float.className='xp-float';
  float.textContent='+'+amount+' XP';
  if(sourceEl){
    const r=sourceEl.getBoundingClientRect();
    float.style.left=r.left+'px';
    float.style.top=r.top+'px';
  } else {
    float.style.right='80px';
    float.style.top='60px';
  }
  document.body.appendChild(float);
  setTimeout(()=>float.remove(),1500);
  announce('+'+amount+' XP earned!');
}

function completeLevel(levelId){
  if(isLevelCompleted(levelId)) return;
  const zone=getZoneForLevel(levelId);
  const level=zone.levels.find(l=>l.id===levelId);
  state.completedLevels.push(levelId);
  state.streak++;
  if(state.streak>state.maxStreak) state.maxStreak=state.streak;

  // Speed bonus
  if(state.levelStartTime && (Date.now()-state.levelStartTime)<120000){
    state.speedBonuses++;
    awardXP(25);
  }
  // Streak bonus
  if(state.streak>0 && state.streak%3===0){ awardXP(75); playSound('streak'); }

  // Leaderboard: record level completion time
  if(!state.leaderboard) state.leaderboard={runs:[],levelTimes:{},zoneCompletionTimes:{}};
  if(state.levelStartTime){
    var lbElapsed=Date.now()-state.levelStartTime;
    if(!state.leaderboard.levelTimes[levelId]||lbElapsed<state.leaderboard.levelTimes[levelId]){
      state.leaderboard.levelTimes[levelId]=lbElapsed;
    }
  }

  // Level complete sound
  playSound('levelcomplete');

  // Level XP
  awardXP(level.xp, document.querySelector('.challenge-submit'));

  // Story unlock
  if(level.story && !state.storiesUnlocked.includes(level.story.id)){
    state.storiesUnlocked.push(level.story.id);
    awardXP(25);
  }

  // Zone completion check
  if(isZoneCompleted(zone.id)){
    playSound('unlock');
    awardXP(zone.bonusXP);
    // Leaderboard: record zone completion time
    if(!state.leaderboard) state.leaderboard={runs:[],levelTimes:{},zoneCompletionTimes:{}};
    if(!state.leaderboard.zoneCompletionTimes) state.leaderboard.zoneCompletionTimes={};
    if(!state.leaderboard.zoneCompletionTimes[zone.id]) state.leaderboard.zoneCompletionTimes[zone.id]=Date.now();
    playSound('zone');
    if(!state.badges.includes(zone.badge.id)){
      state.badges.push(zone.badge.id);
      badgeQueue.push(zone.badge);if(!badgeShowing)setTimeout(showNextBadge,500);
    }
  }

  // Check special badges
  checkSpecialBadges();

  // Graduation check
  if(state.completedLevels.length>=51 && !state.badges.includes('openclaw-master')){
    state.badges.push('openclaw-master');
    // Leaderboard: record game completion run
    if(!state.leaderboard) state.leaderboard={runs:[],levelTimes:{},zoneCompletionTimes:{}};
    state.leaderboard.runs.push({xp:state.xp+1000,badges:state.badges.length+1,time:Date.now()-state.startTime,date:Date.now()});
    badgeQueue.push({id:'openclaw-master',name:'OpenClaw Master',icon:'üëë',desc:'Completed the entire academy!',rarity:'legendary'});if(!badgeShowing)setTimeout(showNextBadge,500);awardXP(1000);
  }

  saveState();
  updateTopBar();
  renderSidebar();
}

// Badge notification queue for sequential display
let badgeQueue=[];
let badgeShowing=false;

function checkSpecialBadges(){
  SPECIAL_BADGES.forEach(b=>{
    if(!state.badges.includes(b.id) && b.condition(state.completedLevels,state)){
      state.badges.push(b.id);
      badgeQueue.push(b);
    }
  });
  if(badgeQueue.length>0 && !badgeShowing) showNextBadge();
}

function showNextBadge(){
  if(badgeQueue.length===0){badgeShowing=false;return;}
  badgeShowing=true;
  const badge=badgeQueue.shift();
  showBadgeCelebration(badge);
}

// ===== UI RENDERING =====
function updateTopBar(){
  const rank=getRank();
  document.getElementById('top-rank').textContent=rank.icon+' '+rank.title;
  document.getElementById('top-xp').textContent='√¢¬≠¬ê '+state.xp.toLocaleString()+' XP';
  document.getElementById('top-badges').textContent='√∞¬ü¬è¬Ü '+state.badges.length+'/'+(11+SPECIAL_BADGES.length);
  const pct=Math.round((state.completedLevels.length/51)*100);
  document.getElementById('top-progress').textContent='√∞¬ü¬ì¬ä '+pct+'%';
}

function renderSidebar(){
  const container=document.getElementById('sidebar-zones');
  let html='<h3>Zones</h3>';
  ZONES.forEach(z=>{
    const unlocked=isZoneUnlocked(z.id);
    const completed=isZoneCompleted(z.id);
    const isCurrent=unlocked&&!completed;
    const cls=completed?'completed':(isCurrent?'active':(unlocked?'':'locked'));
    const status=completed?'√¢¬ú¬Ö':(isCurrent?'√¢¬ñ¬∂√Ø¬∏¬è':(unlocked?'√∞¬ü¬î¬ì':'√∞¬ü¬î¬í'));
    html+=`<div class="zone-item ${cls}" onclick="${unlocked?`toggleZoneLevels(${z.id})`:''}">
      <span>${z.emoji}</span><span style="flex:1">${z.name}</span><span class="zone-status">${status}</span>
    </div>
    <div class="zone-levels" id="zone-levels-${z.id}">`;
    z.levels.forEach(l=>{
      const lUnlocked=isLevelUnlocked(l.id);
      const lCompleted=isLevelCompleted(l.id);
      const lCurrent=lUnlocked&&!lCompleted;
      const lCls=lCompleted?'completed':(lCurrent?'active':(lUnlocked?'':'locked'));
      const lStatus=lCompleted?'√¢¬ú¬Ö':(lCurrent?'√¢¬ñ¬∂√Ø¬∏¬è':'√∞¬ü¬î¬í');
      html+=`<div class="level-item ${lCls}" onclick="${lUnlocked?`openLevel('${l.id}')`:''}">
        <span>${lStatus}</span><span>${l.emoji} ${l.title}</span>
      </div>`;
    });
    html+='</div>';
  });
  container.innerHTML=html;
}

function toggleZoneLevels(zoneId){
  playSound('click');
  const el=document.getElementById('zone-levels-'+zoneId);
  el.classList.toggle('open');
}

// ===== VIEW MANAGEMENT =====
let currentView='map';
function showView(view){
  currentView=view;
  ['zone-map','level-view','trophy-view','stats-view','stories-view','grad-view','leaderboard-view'].forEach(id=>{
    document.getElementById(id).style.display='none';
  });
  document.querySelectorAll('.sidebar-nav button, #mobile-tabs button').forEach(b=>b.classList.remove('active'));

  if(view==='map'){
    document.getElementById('zone-map').style.display='grid';
    renderZoneMap();
    document.getElementById('nav-map')?.classList.add('active');
    document.getElementById('tab-map')?.classList.add('active');
  } else if(view==='level'){
    document.getElementById('level-view').style.display='block';
  } else if(view==='trophies'){
    document.getElementById('trophy-view').style.display='block';
    renderTrophyCase();
    document.getElementById('nav-trophies')?.classList.add('active');
    document.getElementById('tab-trophies')?.classList.add('active');
  } else if(view==='stats'){
    document.getElementById('stats-view').style.display='block';
    renderStats();
    document.getElementById('nav-stats')?.classList.add('active');
    document.getElementById('tab-stats')?.classList.add('active');
  } else if(view==='stories'){
    document.getElementById('stories-view').style.display='block';
    renderStories();
    document.getElementById('nav-stories')?.classList.add('active');
    document.getElementById('tab-stories')?.classList.add('active');
  } else if(view==='leaderboard'){
    document.getElementById('leaderboard-view').style.display='block';
    renderLeaderboard();
    document.getElementById('nav-leaderboard')?.classList.add('active');
    document.getElementById('tab-leaderboard')?.classList.add('active');
  } else if(view==='graduation'){
    document.getElementById('grad-view').style.display='block';
    renderGraduation();
  }
}

// ===== ZONE MAP =====
function renderZoneMap(){
  let html=`<div class="map-header">
    <h1>√∞¬ü¬é¬Æ OpenClaw Academy</h1>
    <p>Master AI agents from zero to hero √¢¬Ä¬î 11 zones, 51 levels, one epic journey</p>
  </div>`;
  ZONES.forEach(z=>{
    const unlocked=isZoneUnlocked(z.id);
    const completed=isZoneCompleted(z.id);
    const isCurrent=unlocked&&!completed;
    const cls=completed?'completed':(isCurrent?'current':(unlocked?'':'locked'));
    const completedCount=z.levels.filter(l=>isLevelCompleted(l.id)).length;
    const pct=Math.round((completedCount/z.levels.length)*100);
    html+=`<div class="zone-card ${cls}" style="--zone-color:${z.color}" onclick="${unlocked?`expandZone(${z.id})`:''}">
      <div class="zone-emoji">${z.emoji}</div>
      <div class="zone-name" style="color:${unlocked?z.color:'var(--locked)'}">${z.name}</div>
      <div class="zone-theme">${z.theme}</div>
      <div class="zone-progress"><div class="zone-progress-fill" style="width:${pct}%;background:${z.color}"></div></div>
      <div class="zone-meta"><span>${completedCount}/${z.levels.length} levels</span><span>${unlocked?(completed?'√¢¬ú¬Ö Complete':'√¢¬ñ¬∂√Ø¬∏¬è In Progress'):'√∞¬ü¬î¬í Locked'}</span></div>
    </div>`;
  });
  // Graduation card
  const allDone=ZONES.every(z=>isZoneCompleted(z.id));
  html+=`<div class="zone-card ${allDone?'completed':'locked'}" style="--zone-color:#FFD700" onclick="${allDone?`showView('graduation')`:''}">
    <div class="zone-emoji">√∞¬ü¬é¬ì</div>
    <div class="zone-name" style="color:${allDone?'#FFD700':'var(--locked)'}">Graduation</div>
    <div class="zone-theme">Complete all zones to graduate</div>
    <div class="zone-meta"><span>Final Ceremony</span><span>${allDone?'√∞¬ü¬é¬ì Ready':'√∞¬ü¬î¬í Locked'}</span></div>
  </div>`;
  document.getElementById('zone-map').innerHTML=html;
}

function expandZone(zoneId){
  playSound('click');
  const el=document.getElementById('zone-levels-'+zoneId);
  // Open sidebar levels
  document.querySelectorAll('.zone-levels').forEach(e=>e.classList.remove('open'));
  if(el) el.classList.add('open');
  // Find first incomplete level
  const z=ZONES.find(z=>z.id===zoneId);
  const nextLevel=z.levels.find(l=>!isLevelCompleted(l.id)&&isLevelUnlocked(l.id));
  if(nextLevel) openLevel(nextLevel.id);
  else if(z.levels.length) openLevel(z.levels[0].id);
}

// ===== LEVEL VIEW =====
function openLevel(levelId){
  const zone=getZoneForLevel(levelId);
  const level=zone.levels.find(l=>l.id===levelId);
  if(!level||!isLevelUnlocked(levelId)) return;
  state.currentLevel=levelId;
  state.levelStartTime=Date.now();
  // Reset challenge state for fresh start
  selectedMC=-1;
  tfScore=0;tfAnswered=0;tfTotal=0;
  saveState();
  showView('level');
  const completed=isLevelCompleted(levelId);
  const color=zone.color;
  let html=`<div class="level-header">
    <div class="level-num" style="color:${color}">Zone ${zone.id}: ${zone.name} √¢¬Ä¬î Level ${level.id}</div>
    <h1>${level.emoji} ${level.title}</h1>
    <span class="level-xp">√¢¬≠¬ê ${level.xp} XP</span>
    ${completed?'<span style="margin-left:8px;color:var(--success);font-size:0.85rem">√¢¬ú¬Ö Completed</span>':''}
  </div>`;

  // Explanation
  html+=`<div class="content-card"><h2>√∞¬ü¬ì¬ñ What Is It?</h2>`;
  level.explanation.split('\n\n').forEach(p=>{
    html+=`<p style="margin-bottom:12px">${p}</p>`;
  });
  html+=`</div>`;

  // Key Takeaway
  html+=`<div class="takeaway-box" style="--zone-color:${color};border-left-color:${color}">
    <h2 style="font-size:0.9rem;margin-bottom:6px;color:${color}">√∞¬ü¬í¬° Key Takeaway</h2>
    <p>${level.keyTakeaway}</p>
  </div>`;

  // Story
  if(level.story){
    const unlocked=state.storiesUnlocked.includes(level.story.id)||completed;
    if(unlocked){
      html+=`<div class="story-card" onclick="this.querySelector('.story-body').classList.toggle('open')">
        <div class="story-header">√∞¬ü¬ì¬ñ <span style="color:var(--gold)">${level.story.title}</span></div>
        <div class="story-who">√∞¬ü¬ë¬§ ${level.story.who}'s Story</div>
        <div class="story-body"><p>${level.story.content}</p>
        <p class="story-lesson">√∞¬ü¬í¬° ${level.story.lesson}</p></div>
      </div>`;
    } else {
      html+=`<div class="story-card locked">
        <div class="story-header">√∞¬ü¬î¬í <span>Complete this level to unlock the story</span></div>
      </div>`;
    }
  }

  // Challenge
  if(!completed){
    html+=renderChallenge(level, zone);
  } else {
    html+=`<div class="content-card" style="border-color:var(--success);background:#39FF1408">
      <h2>√¢¬ú¬Ö Challenge Completed</h2>
      <p style="color:var(--text2)">You've already completed this level's challenge. Great work!</p>
    </div>`;
  }

  // Navigation
  const allLevels=[];
  ZONES.forEach(z=>z.levels.forEach(l=>allLevels.push(l.id)));
  const idx=allLevels.indexOf(levelId);
  html+=`<div class="level-nav">`;
  if(idx>0){
    const prev=allLevels[idx-1];
    html+=`<button class="btn-outline" onclick="openLevel('${prev}')">√¢¬Ü¬ê Previous</button>`;
  } else html+=`<span></span>`;
  if(idx<allLevels.length-1 && completed){
    const next=allLevels[idx+1];
    if(isLevelUnlocked(next)){
      html+=`<button class="btn-primary" style="--zone-color:${color}" onclick="openLevel('${next}')">Next Level √¢¬Ü¬í</button>`;
    }
  }
  html+=`</div>`;

  document.getElementById('level-view').innerHTML=html;
  document.getElementById('level-view').scrollTop=0;
  window.scrollTo(0,0);
  renderSidebar();
}

// ===== CHALLENGE RENDERER =====
function renderChallenge(level, zone){
  const c=level.challenge;
  const color=zone.color;
  let html=`<div class="challenge-area" style="--zone-color:${color}" id="challenge-area">
    <h2>√∞¬ü¬é¬Ø Challenge</h2>
    <div class="question">${c.question}</div>`;

  switch(c.type){
    case 'multiple-choice':
      html+=renderMC(c, level.id, color);
      break;
    case 'drag-match':
      html+=renderDragMatch(c, level.id, color);
      break;
    case 'ordering':
      html+=renderOrdering(c, level.id, color);
      break;
    case 'fill-blank':
      html+=renderFillBlank(c, level.id, color);
      break;
    case 'true-false':
      html+=renderTrueFalse(c, level.id, color);
      break;
    case 'creative':
      html+=renderCreative(c, level.id, color);
      break;
    case 'checklist':
      html+=renderChecklist(c, level.id, color);
      break;
  }

  html+=`<div class="challenge-result" id="challenge-result"></div></div>`;
  return html;
}

// Multiple Choice
function renderMC(c, levelId, color){
  let html=`<div class="mc-options" id="mc-options" role="radiogroup">`;
  c.options.forEach((opt,i)=>{
    html+=`<div class="mc-option" data-idx="${i}" onclick="selectMC(this,${i})" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectMC(this,${i})}" tabindex="0" role="radio" aria-checked="false">
      <div class="radio"></div><span>${opt}</span>
    </div>`;
  });
  html+=`</div>
  <button class="challenge-submit btn-primary" style="--zone-color:${color}" onclick="submitMC('${levelId}',${c.correct})" id="mc-submit">Submit Answer</button>`;
  return html;
}
let selectedMC=-1;
function selectMC(el,idx){
  if(el.closest('.challenge-area').querySelector('.mc-option.correct')) return;
  playSound('click');
  selectedMC=idx;
  el.closest('.mc-options').querySelectorAll('.mc-option').forEach(o=>{o.classList.remove('selected');o.setAttribute('aria-checked','false');});
  el.classList.add('selected');
  el.setAttribute('aria-checked','true');
}
function submitMC(levelId,correctIdx){
  if(selectedMC<0) return;
  const options=document.querySelectorAll('#mc-options .mc-option');
  const result=document.getElementById('challenge-result');
  options.forEach(o=>{
    const idx=parseInt(o.dataset.idx);
    if(idx===correctIdx) o.classList.add('correct');
    else if(idx===selectedMC) o.classList.add('wrong');
    o.style.pointerEvents='none';
  });
  if(selectedMC===correctIdx){
    result.className='challenge-result success';
    result.textContent='√∞¬ü¬é¬â Correct! Well done!';
    playSound('success');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:true,attempts:1};
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),800);
  } else {
    result.className='challenge-result fail';
    result.textContent='√¢¬ù¬å Not quite. The correct answer is highlighted in green.';
    playSound('wrong');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:false,attempts:1};
    else state.quizResults[levelId].attempts++;
    // Still complete on wrong answer
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),1200);
  }
  saveState();
  selectedMC=-1;
}

// Drag & Drop Matching
function renderDragMatch(c, levelId, color){
  const shuffled=[...c.pairs].sort(()=>Math.random()-0.5);
  const targets=[...new Set(c.pairs.map(p=>p.target))].sort(()=>Math.random()-0.5);
  let html=`<div class="dd-container" id="dd-container" data-level="${levelId}" data-total="${targets.length}">
    <div><div class="dd-label">Drag these items:</div><div class="dd-items" id="dd-items">`;
  // Collect unique items
  const items=[...new Set(c.pairs.map(p=>p.item))].sort(()=>Math.random()-0.5);
  items.forEach((item,i)=>{
    html+=`<div class="dd-item" draggable="true" data-item="${item}" id="dd-item-${i}"
      ondragstart="ddStart(event)" ondragend="ddEnd(event)">${item}</div>`;
  });
  html+=`</div></div><div><div class="dd-label">Drop onto targets:</div><div class="dd-targets" id="dd-targets">`;
  targets.forEach((t,i)=>{
    html+=`<div class="dd-target" data-target="${t}" id="dd-target-${i}"
      ondragover="ddOver(event)" ondragleave="ddLeave(event)" ondrop="ddDrop(event)">${t}</div>`;
  });
  html+=`</div></div></div>
  <button class="challenge-submit btn-primary" style="--zone-color:${color}" onclick="submitDD('${levelId}')" id="dd-submit">Check Matches</button>`;
  return html;
}
let ddData='';
function ddStart(e){e.dataTransfer.setData('text',e.target.dataset.item);ddData=e.target.dataset.item;e.target.classList.add('dragging');playSound('drag');}
function ddEnd(e){e.target.classList.remove('dragging');}
function ddOver(e){e.preventDefault();e.currentTarget.classList.add('over');}
function ddLeave(e){e.currentTarget.classList.remove('over');}
function ddDrop(e){
  e.preventDefault();
  e.currentTarget.classList.remove('over');
  const item=e.dataTransfer.getData('text');
  e.currentTarget.dataset.dropped=item;
  e.currentTarget.innerHTML=`<strong>${item}</strong> √¢¬Ü¬í ${e.currentTarget.dataset.target}`;
  (e.currentTarget.classList.add('filled');
  playSound('drop');
})
function submitDD(levelId){
  const container=document.getElementById('dd-container');
  const zone=getZoneForLevel(levelId);
  const level=zone.levels.find(l=>l.id===levelId);
  const pairs=level.challenge.pairs;
  const targets=document.querySelectorAll('#dd-targets .dd-target');
  let correct=0, total=targets.length;
  // Build lookup: target -> valid items
  const lookup={};
  pairs.forEach(p=>{if(!lookup[p.target])lookup[p.target]=[];lookup[p.target].push(p.item);});
  targets.forEach(t=>{
    const dropped=t.dataset.dropped;
    const target=t.dataset.target;
    if(dropped && lookup[target] && lookup[target].includes(dropped)){
      t.classList.add('filled');t.classList.remove('wrong-fill');correct++;
    } else if(dropped){
      t.classList.add('wrong-fill');t.classList.remove('filled');
    }
  });
  const result=document.getElementById('challenge-result');
  if(correct>=Math.ceil(total*0.6)){
    result.className='challenge-result success';
    result.textContent=`√∞¬ü¬é¬â ${correct}/${total} correct! Great matching!`;
    playSound('success');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:correct===total,attempts:1};
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),800);
  } else {
    result.className='challenge-result fail';
    result.textContent=`√¢¬ù¬å ${correct}/${total} correct. Try dragging items to different targets.`;
    playSound('wrong');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:false,perfect:false,attempts:1};
    else state.quizResults[levelId].attempts++;
    // Complete anyway after attempt
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),1200);
  }
  saveState();
}

// Ordering
function renderOrdering(c, levelId, color){
  const shuffled=c.items.map((item,i)=>({text:item,origIdx:i})).sort(()=>Math.random()-0.5);
  let html=`<div class="order-list" id="order-list" data-level="${levelId}">`;
  shuffled.forEach((item,i)=>{
    html+=`<div class="order-item" draggable="true" data-orig="${item.origIdx}"
      ondragstart="orderDragStart(event,${i})" ondragover="orderDragOver(event)" ondrop="orderDrop(event,${i})">
      <span class="grip">√¢¬Ý¬ø</span><span>${item.text}</span>
    </div>`;
  });
  html+=`</div>
  <button class="challenge-submit btn-primary" style="--zone-color:${color}" onclick="submitOrder('${levelId}')" id="order-submit">Check Order</button>`;
  return html;
}
let orderDragIdx=-1;
function orderDragStart(e,idx){orderDragIdx=idx;e.dataTransfer.effectAllowed='move';playSound('drag');}
function orderDragOver(e){e.preventDefault();}
function orderDrop(e,dropIdx){
  e.preventDefault();
  const list=document.getElementById('order-list');
  const items=[...list.children];
  if(orderDragIdx<0||orderDragIdx===dropIdx) return;
  const dragEl=items[orderDragIdx];
  const dropEl=items[dropIdx];
  if(orderDragIdx<dropIdx) list.insertBefore(dragEl,dropEl.nextSibling);
  (else list.insertBefore(dragEl,dropEl);
  orderDragIdx=-1;
  playSound('drop');
})
function submitOrder(levelId){
  const zone=getZoneForLevel(levelId);
  const level=zone.levels.find(l=>l.id===levelId);
  const list=document.getElementById('order-list');
  const items=[...list.children];
  let correct=0;
  items.forEach((el,i)=>{
    const orig=parseInt(el.dataset.orig);
    if(orig===level.challenge.correctOrder[i]){
      el.classList.add('correct-pos');correct++;
    } else {
      el.classList.add('wrong-pos');
    }
  });
  const result=document.getElementById('challenge-result');
  const total=items.length;
  if(correct>=Math.ceil(total*0.8)){
    result.className='challenge-result success';
    result.textContent=`√∞¬ü¬é¬â ${correct}/${total} in correct position! Great sequencing!`;
    playSound('success');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:correct===total,attempts:1};
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),800);
  } else {
    result.className='challenge-result fail';
    result.textContent=`√¢¬ù¬å ${correct}/${total} correct. Green = right position, red = wrong.`;
    playSound('wrong');
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),1200);
  }
  saveState();
}

// Fill in the Blank
function renderFillBlank(c, levelId, color){
  let html='';
  c.blanks.forEach((b,i)=>{
    html+=`<div class="fill-group">
      <label>${b.prompt}</label>
      <input type="text" class="fill-blank-input" id="fill-${i}" placeholder="Type your answer..." autocomplete="off">
    </div>`;
  });
  html+=`<button class="challenge-submit btn-primary" style="--zone-color:${color}" onclick="submitFill('${levelId}')" id="fill-submit">Submit</button>`;
  return html;
}
function submitFill(levelId){
  const zone=getZoneForLevel(levelId);
  const level=zone.levels.find(l=>l.id===levelId);
  const blanks=level.challenge.blanks;
  let correct=0;
  blanks.forEach((b,i)=>{
    const input=document.getElementById('fill-'+i);
    const val=input.value.trim().toLowerCase().replace(/[,$]/g,'');
    const match=b.answer.some(a=>val===a.toLowerCase()||val.includes(a.toLowerCase()));
    if(match){input.classList.add('correct');correct++;}
    else{input.classList.add('wrong');}
    input.disabled=true;
  });
  const result=document.getElementById('challenge-result');
  if(correct>=Math.ceil(blanks.length*0.5)){
    result.className='challenge-result success';
    result.textContent='√∞¬ü¬é¬â Correct! Well done!';
    playSound('success');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:correct===blanks.length,attempts:1};
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),800);
  } else {
    result.className='challenge-result fail';
    result.textContent='√¢¬ù¬å Not quite right. Check the highlighted fields.';
    playSound('wrong');
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),1200);
  }
  saveState();
}

// True/False Rapid Fire
function renderTrueFalse(c, levelId, color){
  let html='<div id="tf-container">';
  c.statements.forEach((s,i)=>{
    html+=`<div class="tf-question" id="tf-q-${i}">
      <div class="tf-text">${s.text}</div>
      <div class="tf-buttons">
        <button class="tf-btn true-btn" onclick="answerTF(${i},true,'${levelId}')">True</button>
        <button class="tf-btn false-btn" onclick="answerTF(${i},false,'${levelId}')">False</button>
      </div>
    </div>`;
  });
  html+='</div>';
  return html;
}
let tfScore=0, tfTotal=0, tfAnswered=0;
function answerTF(idx, answer, levelId){
  const zone=getZoneForLevel(levelId);
  const level=zone.levels.find(l=>l.id===levelId);
  const stmt=level.challenge.statements[idx];
  const q=document.getElementById('tf-q-'+idx);
  if(q.classList.contains('answered')) return;
  playSound('click');
  q.classList.add('answered');
  const btns=q.querySelectorAll('.tf-btn');
  const correct=answer===stmt.answer;
  btns.forEach(b=>{
    if(b.classList.contains('true-btn')&&answer===true) b.classList.add(correct?'chosen-correct':'chosen-wrong');
    if(b.classList.contains('false-btn')&&answer===false) b.classList.add(correct?'chosen-correct':'chosen-wrong');
    b.disabled=true;
  });
  if(correct){tfScore++;playSound('xp');}else{playSound('wrong');}
  tfAnswered++;
  tfTotal=level.challenge.statements.length;
  if(tfAnswered>=tfTotal){
    const result=document.getElementById('challenge-result');
    if(tfScore>=Math.ceil(tfTotal*0.6)){
      result.className='challenge-result success';
      result.textContent=`√∞¬ü¬é¬â ${tfScore}/${tfTotal} correct! Nice rapid fire!`;
      playSound('success');
    } else {
      result.className='challenge-result fail';
      result.textContent=`√¢¬ù¬å ${tfScore}/${tfTotal} correct. Keep learning!`;
    }
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:tfScore===tfTotal,attempts:1};
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),1000);
    saveState();
    tfScore=0;tfAnswered=0;
  }
}

// Creative Input
function renderCreative(c, levelId, color){
  let html=`<textarea class="creative-textarea" id="creative-input" placeholder="${c.placeholder||'Write your answer here...'}"></textarea>
  <button class="challenge-submit btn-primary" style="--zone-color:${color}" onclick="submitCreative('${levelId}')" id="creative-submit">Submit</button>`;
  return html;
}
function submitCreative(levelId){
  const val=document.getElementById('creative-input').value.trim();
  const result=document.getElementById('challenge-result');
  if(val.length>0){
    result.className='challenge-result success';
    result.textContent='√∞¬ü¬é¬â Great response! Every agent personality is unique.';
    playSound('success');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:true,attempts:1};
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),800);
  } else {
    result.className='challenge-result fail';
    result.textContent='Please write something before submitting.';
    playSound('wrong');
  }
  saveState();
}

// Checklist
function renderChecklist(c, levelId, color){
  let html=`<div id="checklist-container">`;
  c.items.forEach((item,i)=>{
    html+=`<label class="checklist-item" onclick="this.classList.toggle('checked');playSound('click')">
      <input type="checkbox" data-idx="${i}" data-good="${item.good}">
      <span>${item.text}</span>
    </label>`;
  });
  html+=`</div>
  <button class="challenge-submit btn-primary" style="--zone-color:${color}" onclick="submitChecklist('${levelId}')" id="checklist-submit">Submit</button>`;
  return html;
}
function submitChecklist(levelId){
  const zone=getZoneForLevel(levelId);
  const level=zone.levels.find(l=>l.id===levelId);
  const checks=document.querySelectorAll('#checklist-container input[type=checkbox]');
  let correct=0, total=checks.length;
  checks.forEach(ch=>{
    const isGood=ch.dataset.good==='true';
    const isChecked=ch.checked;
    const item=ch.closest('.checklist-item');
    if((isGood&&isChecked)||(!isGood&&!isChecked)){
      correct++;
      if(isChecked) item.style.borderColor='var(--success)';
    } else {
      item.style.borderColor='var(--error)';
    }
    ch.disabled=true;
  });
  const result=document.getElementById('challenge-result');
  if(correct>=Math.ceil(total*0.7)){
    result.className='challenge-result success';
    result.textContent=`√∞¬ü¬é¬â ${correct}/${total} correct selections!`;
    playSound('success');
    if(!state.quizResults[levelId]) state.quizResults[levelId]={passed:true,perfect:correct===total,attempts:1};
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),800);
  } else {
    result.className='challenge-result fail';
    result.textContent=`√¢¬ù¬å ${correct}/${total} correct. Green borders = right, red = wrong.`;
    playSound('wrong');
    completeLevel(levelId);
    setTimeout(()=>openLevel(levelId),1200);
  }
  saveState();
}

// ===== LEADERBOARD =====
let lbCurrentTab='top-scores';

function renderLeaderboard(){
  if(!state.leaderboard) state.leaderboard={runs:[],levelTimes:{},zoneCompletionTimes:{}};
  const lb=state.leaderboard;
  let html='<h1 style="margin-bottom:4px">\uD83C\uDFC5 Leaderboard</h1>';
  html+='<p style="color:var(--text2);margin-bottom:8px">Your personal records \u2014 top scores, fastest times, and best streaks</p>';
  const fastestLevel=Object.entries(lb.levelTimes||{}).sort((a,b)=>a[1]-b[1])[0];
  const zonesCompleted=Object.keys(lb.zoneCompletionTimes||{}).length;
  html+='<div class="lb-personal-best"><h3>\u2B50 Personal Bests</h3><div class="lb-pb-grid">';
  html+='<div class="lb-pb-item"><span class="pb-val">'+state.xp.toLocaleString()+'</span><span class="pb-label">Highest XP</span></div>';
  html+='<div class="lb-pb-item"><span class="pb-val">'+state.maxStreak+'</span><span class="pb-label">Best Streak</span></div>';
  html+='<div class="lb-pb-item"><span class="pb-val">'+(fastestLevel?formatTime(fastestLevel[1]):'--')+'</span><span class="pb-label">Fastest Level</span></div>';
  html+='<div class="lb-pb-item"><span class="pb-val">'+state.completedLevels.length+'/51</span><span class="pb-label">Levels Done</span></div>';
  html+='<div class="lb-pb-item"><span class="pb-val">'+zonesCompleted+'/11</span><span class="pb-label">Zones Done</span></div>';
  html+='<div class="lb-pb-item"><span class="pb-val">'+Object.values(state.quizResults||{}).filter(function(q){return q.perfect}).length+'</span><span class="pb-label">Perfect Quizzes</span></div>';
  html+='</div></div>';
  html+='<div class="lb-tabs">';
  html+='<button class="lb-tab '+(lbCurrentTab==='top-scores'?'active':'')+'" onclick="lbCurrentTab=\'top-scores\';renderLeaderboard()">\uD83C\uDFC6 Top Scores</button>';
  html+='<button class="lb-tab '+(lbCurrentTab==='fastest'?'active':'')+'" onclick="lbCurrentTab=\'fastest\';renderLeaderboard()">\u26A1 Fastest Levels</button>';
  html+='<button class="lb-tab '+(lbCurrentTab==='zones'?'active':'')+'" onclick="lbCurrentTab=\'zones\';renderLeaderboard()">\uD83D\uDDFA\uFE0F Zone Times</button>';
  html+='<button class="lb-tab '+(lbCurrentTab==='streaks'?'active':'')+'" onclick="lbCurrentTab=\'streaks\';renderLeaderboard()">\uD83D\uDD25 Streaks</button>';
  html+='</div>';
  if(lbCurrentTab==='top-scores') html+=renderLBTopScores(lb);
  else if(lbCurrentTab==='fastest') html+=renderLBFastestLevels(lb);
  else if(lbCurrentTab==='zones') html+=renderLBZoneTimes(lb);
  else if(lbCurrentTab==='streaks') html+=renderLBStreaks(lb);
  html+='<div style="text-align:center;margin-top:20px"><button class="lb-clear-btn" onclick="clearLeaderboard()">\uD83D\uDDD1\uFE0F Clear Leaderboard Data</button></div>';
  document.getElementById('leaderboard-view').innerHTML=html;
}

function renderLBTopScores(lb){
  var runs=((lb.runs||[]).map(function(r,i){return Object.assign({},r,{idx:i})}));
  runs.push({xp:state.xp,badges:state.badges.length,time:Date.now()-state.startTime,date:Date.now(),live:true});
  runs.sort(function(a,b){return b.xp-a.xp});
  var top=runs.slice(0,10);
  if(top.length===0) return renderLBEmpty('No scores recorded yet','Complete levels to see your scores here');
  var html='<table class="lb-table"><thead><tr><th>Rank</th><th>Score</th><th>Badges</th><th>Time</th><th style="text-align:right">Date</th></tr></thead><tbody>';
  top.forEach(function(r,i){
    var rankCls=i===0?'gold':(i===1?'silver':(i===2?'bronze':''));
    var medal=i===0?'\uD83E\uDD47':(i===1?'\uD83E\uDD48':(i===2?'\uD83E\uDD49':'#'+(i+1)));
    var rowCls=r.live?'lb-highlight':'';
    html+='<tr class="'+rowCls+'"><td class="lb-rank '+rankCls+'">'+medal+'</td><td class="lb-name">'+r.xp.toLocaleString()+' XP '+(r.live?'<span style="color:var(--z1);font-size:0.75rem">(current)</span>':'')+'</td><td>\uD83C\uDFC6 '+r.badges+'</td><td class="lb-value">'+formatTimeLong(r.time)+'</td><td class="lb-date">'+formatDate(r.date)+'</td></tr>';
  });
  html+='</tbody></table>';
  return html;
}

function renderLBFastestLevels(lb){
  var times=Object.entries(lb.levelTimes||{});
  if(times.length===0) return renderLBEmpty('No level times recorded','Complete levels to track your speed');
  times.sort(function(a,b){return a[1]-b[1]});
  var top=times.slice(0,15);
  var html='<table class="lb-table"><thead><tr><th>Rank</th><th>Level</th><th style="text-align:right">Time</th></tr></thead><tbody>';
  top.forEach(function(entry,i){
    var levelId=entry[0],time=entry[1];
    var zone=getZoneForLevel(levelId);
    var level=zone?zone.levels.find(function(l){return l.id===levelId}):null;
    var rankCls=i===0?'gold':(i===1?'silver':(i===2?'bronze':''));
    var medal=i===0?'\uD83E\uDD47':(i===1?'\uD83E\uDD48':(i===2?'\uD83E\uDD49':'#'+(i+1)));
    html+='<tr><td class="lb-rank '+rankCls+'">'+medal+'</td><td class="lb-name">'+(level?level.emoji:'')+' '+(level?level.title:levelId)+' <span style="color:var(--text2);font-size:0.8rem">('+(zone?zone.name:'')+')</span></td><td class="lb-value">'+formatTime(time)+'</td></tr>';
  });
  html+='</tbody></table>';
  return html;
}

function renderLBZoneTimes(lb){
  var zoneTimes=lb.zoneCompletionTimes||{};
  if(Object.keys(zoneTimes).length===0) return renderLBEmpty('No zones completed yet','Finish a zone to see your zone records');
  var entries=ZONES.filter(function(z){return zoneTimes[z.id]}).map(function(z){
    return {zone:z,time:zoneTimes[z.id]-state.startTime,timestamp:zoneTimes[z.id]};
  });
  entries.sort(function(a,b){return a.time-b.time});
  var html='<table class="lb-table"><thead><tr><th>Order</th><th>Zone</th><th style="text-align:right">Completed At</th></tr></thead><tbody>';
  entries.forEach(function(e,i){
    var rankCls=i===0?'gold':(i===1?'silver':(i===2?'bronze':''));
    html+='<tr><td class="lb-rank '+rankCls+'">'+(i+1)+'</td><td class="lb-name"><span style="color:'+e.zone.color+'">'+e.zone.emoji+' '+e.zone.name+'</span></td><td class="lb-value">'+formatTimeLong(e.time)+'</td></tr>';
  });
  html+='</tbody></table>';
  return html;
}

function renderLBStreaks(lb){
  var perfectStreak=0,bestPerfect=0;
  var allLevels=[];
  ZONES.forEach(function(z){z.levels.forEach(function(l){allLevels.push(l.id)})});
  allLevels.forEach(function(lid){
    if(state.quizResults[lid]&&state.quizResults[lid].perfect){perfectStreak++;if(perfectStreak>bestPerfect)bestPerfect=perfectStreak;}else{perfectStreak=0;}
  });
  var html='<div class="stats-grid" style="margin-bottom:16px">';
  html+='<div class="stat-card"><h3>\uD83D\uDD25 Current Streak</h3><div class="stat-value" style="font-family:var(--font-head);font-size:1.8rem;color:var(--gold)">'+state.streak+'</div><p style="color:var(--text2);font-size:0.8rem;margin-top:4px">levels in a row</p></div>';
  html+='<div class="stat-card"><h3>\uD83C\uDFC6 Best Streak</h3><div class="stat-value" style="font-family:var(--font-head);font-size:1.8rem;color:var(--gold)">'+state.maxStreak+'</div><p style="color:var(--text2);font-size:0.8rem;margin-top:4px">levels in a row (all time)</p></div>';
  html+='<div class="stat-card"><h3>\uD83D\uDCAF Perfect Quiz Streak</h3><div class="stat-value" style="font-family:var(--font-head);font-size:1.8rem;color:var(--gold)">'+bestPerfect+'</div><p style="color:var(--text2);font-size:0.8rem;margin-top:4px">perfect quizzes in a row</p></div>';
  html+='<div class="stat-card"><h3>\u26A1 Speed Bonuses</h3><div class="stat-value" style="font-family:var(--font-head);font-size:1.8rem;color:var(--gold)">'+state.speedBonuses+'</div><p style="color:var(--text2);font-size:0.8rem;margin-top:4px">levels under 2 min</p></div>';
  html+='</div>';
  html+='<div class="content-card"><h2>\uD83C\uDFAF Streak Milestones</h2>';
  var milestones=[{target:3,label:'Warm Up',icon:'\uD83C\uDF21\uFE0F'},{target:5,label:'On Fire',icon:'\uD83D\uDD25'},{target:10,label:'Unstoppable',icon:'\uD83D\uDCAA'},{target:20,label:'Machine Mode',icon:'\uD83E\uDD16'},{target:51,label:'Perfect Run',icon:'\uD83D\uDC51'}];
  milestones.forEach(function(m){
    var achieved=state.maxStreak>=m.target;
    var pct=Math.min(100,Math.round((state.maxStreak/m.target)*100));
    html+='<div style="display:flex;align-items:center;gap:12px;padding:8px 0;opacity:'+(achieved?1:0.5)+'">';
    html+='<span style="font-size:1.3rem">'+(achieved?m.icon:'\uD83D\uDD12')+'</span>';
    html+='<div style="flex:1"><div style="font-weight:600;font-size:0.9rem">'+m.label+' \u2014 '+m.target+' in a row '+(achieved?'\u2705':'')+'</div>';
    html+='<div class="stat-bar" style="margin-top:4px"><div class="stat-bar-fill" style="width:'+pct+'%;background:'+(achieved?'var(--gold)':'var(--text2)')+'"></div></div></div>';
    html+='</div>';
  });
  html+='</div>';
  return html;
}

function renderLBEmpty(title,subtitle){
  return '<div class="lb-empty"><span class="lb-empty-icon">\uD83C\uDFC5</span><p><strong>'+title+'</strong></p><p>'+subtitle+'</p></div>';
}

function formatTime(ms){
  if(!ms||ms<0) return '--';
  var s=Math.floor(ms/1000);
  if(s<60) return s+'s';
  var m=Math.floor(s/60);
  var rs=s%60;
  return m+'m '+rs+'s';
}

function formatTimeLong(ms){
  if(!ms||ms<0) return '--';
  var s=Math.floor(ms/1000);
  if(s<60) return s+'s';
  var m=Math.floor(s/60);
  if(m<60){var rs=s%60;return m+'m '+rs+'s';}
  var h=Math.floor(m/60);
  var rm=m%60;
  return h+'h '+rm+'m';
}

function formatDate(ts){
  if(!ts) return '--';
  var d=new Date(ts);
  return d.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'});
}

function clearLeaderboard(){
  if(!confirm('Clear all leaderboard records? Your game progress will be preserved.')) return;
  state.leaderboard={runs:[],levelTimes:{},zoneCompletionTimes:{}};
  saveState();
  renderLeaderboard();
}

// ===== TROPHY CASE =====
function renderTrophyCase(){
  const totalBadges=11+SPECIAL_BADGES.length;
  const earnedCount=state.badges.length;
  const pct=Math.round((earnedCount/totalBadges)*100);
  const rarityCount={common:0,rare:0,epic:0,legendary:0};
  const earnedRarity={common:0,rare:0,epic:0,legendary:0};
  ZONES.forEach(z=>{rarityCount.rare++;if(state.badges.includes(z.badge.id))earnedRarity.rare++});
  SPECIAL_BADGES.forEach(b=>{rarityCount[b.rarity]++;if(state.badges.includes(b.id))earnedRarity[b.rarity]++});
  const rarityLabels={common:"Common",rare:"Rare",epic:"Epic",legendary:"Legendary"};

  let html=`<h1 style="margin-bottom:4px">üèÜ Achievement Trophy Case</h1>
  <p style="color:var(--text2);margin-bottom:4px">${earnedCount} of ${totalBadges} badges earned ‚Äî ${pct}% complete</p>
  <div class="trophy-header-stats">
    <div class="trophy-stat-card"><div class="ts-val">${earnedCount}/${totalBadges}</div><div class="ts-lbl">Badges</div></div>
    <div class="trophy-stat-card"><div class="ts-val" style="color:#8888AA">${earnedRarity.common}/${rarityCount.common}</div><div class="ts-lbl">Common</div></div>
    <div class="trophy-stat-card"><div class="ts-val" style="color:#00F0FF">${earnedRarity.rare}/${rarityCount.rare}</div><div class="ts-lbl">Rare</div></div>
    <div class="trophy-stat-card"><div class="ts-val" style="color:#BF00FF">${earnedRarity.epic}/${rarityCount.epic}</div><div class="ts-lbl">Epic</div></div>
    <div class="trophy-stat-card"><div class="ts-val" style="color:#FFD700">${earnedRarity.legendary}/${rarityCount.legendary}</div><div class="ts-lbl">Legendary</div></div>
  </div>`;

  // Zone Mastery category
  const zoneEarned=ZONES.filter(z=>state.badges.includes(z.badge.id)).length;
  html+=`<div class="trophy-category">
    <div class="trophy-category-header"><h2>üó∫Ô∏è Zone Mastery</h2><span class="cat-progress">${zoneEarned}/11</span></div>
    <div class="trophy-grid">`;
  ZONES.forEach(z=>{
    const earned=state.badges.includes(z.badge.id);
    const completedCount=z.levels.filter(l=>state.completedLevels.includes(l.id)).length;
    const prog=Math.round((completedCount/z.levels.length)*100);
    html+=`<div class="badge-card ${earned?'earned':'locked'}">
      <span class="badge-rarity rarity-rare">Rare</span>
      <span class="badge-icon">${earned?z.badge.icon:'‚ùì'}</span>
      <div class="badge-name">${z.badge.name}</div>
      <div class="badge-desc">${earned?z.badge.desc:'Complete Zone '+z.id}</div>
      ${!earned?`<div class="badge-progress"><div class="badge-progress-fill" style="width:${prog}%"></div></div><div class="badge-progress-text">${completedCount}/${z.levels.length} levels</div>`:''}</div>`;
  });
  html+=`</div></div>`;

  // Achievement categories
  const categories=[
    {key:"progression",label:"üìà Progression",desc:"Journey milestones"},
    {key:"mastery",label:"üéØ Mastery",desc:"Prove your skill"},
    {key:"speed",label:"‚ö° Speed & Streaks",desc:"Fast and furious"},
    {key:"collection",label:"üì¶ Collection",desc:"Gather them all"},
    {key:"ultimate",label:"üëë Ultimate",desc:"The final frontier"}
  ];
  categories.forEach(cat=>{
    const catBadges=SPECIAL_BADGES.filter(b=>b.category===cat.key);
    if(!catBadges.length)return;
    const catEarned=catBadges.filter(b=>state.badges.includes(b.id)).length;
    html+=`<div class="trophy-category">
      <div class="trophy-category-header"><h2>${cat.label}</h2><span class="cat-progress">${catEarned}/${catBadges.length}</span></div>
      <div class="trophy-grid">`;
    catBadges.forEach(b=>{
      const earned=state.badges.includes(b.id);
      const rarCls='rarity-'+b.rarity;
      const cardCls=earned?'rarity-'+b.rarity+'-card':'';
      let progHtml='';
      if(!earned&&b.progress){
        const p=b.progress(state.completedLevels,state);
        const pPct=Math.round((p.current/p.target)*100);
        progHtml=`<div class="badge-progress"><div class="badge-progress-fill" style="width:${pPct}%"></div></div><div class="badge-progress-text">${p.current}/${p.target}</div>`;
      }
      html+=`<div class="badge-card ${earned?'earned':'locked'} ${cardCls}">
        <span class="badge-rarity ${rarCls}">${rarityLabels[b.rarity]}</span>
        <span class="badge-icon">${earned?b.icon:'‚ùì'}</span>
        <div class="badge-name">${b.name}</div>
        <div class="badge-desc">${earned?b.desc:'Keep playing to unlock'}</div>
        ${progHtml}</div>`;
    });
    html+=`</div></div>`;
  });

  document.getElementById('trophy-view').innerHTML=html;
}

// ===== STATS VIEW =====
function renderStats(){
  const rank=getRank();
  const nextRank=getNextRank();
  const totalLevels=51;
  const totalStories=ALL_STORIES.length;
  const elapsed=Math.floor((Date.now()-state.startTime)/60000);
  const hours=Math.floor(elapsed/60);
  const mins=elapsed%60;

  let html=`<h1 style="margin-bottom:16px">√∞¬ü¬ì¬ä Your Stats</h1>
  <div class="stat-card">
    <h3>Current Rank</h3>
    <div class="stat-value">${rank.icon} ${rank.title}</div>
    ${nextRank?`<div style="color:var(--text2);font-size:0.85rem;margin-top:4px">Next: ${nextRank.icon} ${nextRank.title} at ${nextRank.xp.toLocaleString()} XP</div>
    <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.min(100,((state.xp-rank.xp)/(nextRank.xp-rank.xp))*100)}%;background:var(--gold)"></div></div>`:'<div style="color:var(--gold);margin-top:4px">√∞¬ü¬é¬â Maximum rank achieved!</div>'}
  </div>
  <div class="stats-grid">
    <div class="stat-card"><h3>Total XP</h3><div class="stat-value">${state.xp.toLocaleString()}</div></div>
    <div class="stat-card"><h3>Levels Completed</h3><div class="stat-value">${state.completedLevels.length}/${totalLevels}</div></div>
    <div class="stat-card"><h3>Zones Completed</h3><div class="stat-value">${ZONES.filter(z=>isZoneCompleted(z.id)).length}/11</div></div>
    <div class="stat-card"><h3>Stories Unlocked</h3><div class="stat-value">${state.storiesUnlocked.length}/${totalStories}</div></div>
    <div class="stat-card"><h3>Badges Earned</h3><div class="stat-value">${state.badges.length}/${11+SPECIAL_BADGES.length}</div></div>
    <div class="stat-card"><h3>Current Streak</h3><div class="stat-value">√∞¬ü¬î¬• ${state.streak}</div></div>
    <div class="stat-card"><h3>Best Streak</h3><div class="stat-value">√∞¬ü¬î¬• ${state.maxStreak}</div></div>
