// ===== THEME TOGGLE =====
function applyTheme(theme){
  document.documentElement.setAttribute('data-theme',theme);
  document.getElementById('theme-toggle').textContent=theme==='light'?'‚òÄÔ∏è':'üåô';
  document.querySelector('meta[name="theme-color"]').setAttribute('content',theme==='light'?'#F0F2F5':'#0A0A0F');
}
document.getElementById('theme-toggle').addEventListener('click',()=>{
  var current=document.documentElement.getAttribute('data-theme')||'dark';
  var next=current==='dark'?'light':'dark';
  applyTheme(next);
  try{localStorage.setItem('openclaw_theme',next);}catch(e){}
  playSound('click');
});
// Apply saved theme immediately
(function(){
  try{var t=localStorage.getItem('openclaw_theme');if(t)applyTheme(t);}catch(e){}
  // Also respect OS preference if no saved preference
  if(!localStorage.getItem('openclaw_theme')&&window.matchMedia&&window.matchMedia('(prefers-color-scheme:light)').matches){
    applyTheme('light');
  }
})();
