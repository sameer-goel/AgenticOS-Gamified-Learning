function renderStories(){
  let html=`<h1 style="margin-bottom:4px">√∞¬ü¬ì¬ñ Real Stories</h1>
  <p style="color:var(--text2);margin-bottom:16px">${state.storiesUnlocked.length} of ${ALL_STORIES.length} stories unlocked</p>
