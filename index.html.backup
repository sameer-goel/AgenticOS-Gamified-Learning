  {xp:0,title:"Curious Human",icon:"√∞¬ü¬ê¬£"},
  {xp:500,title:"Agent Apprentice",icon:"√∞¬ü¬å¬±"},
  {xp:1200,title:"Loop Runner",icon:"√∞¬ü¬î¬Ñ"},
  {xp:2200,title:"DNA Coder",icon:"√∞¬ü¬ß¬¨"},
  {xp:3200,title:"Memory Weaver",icon:"√∞¬ü¬ß¬Ý"},
  {xp:4500,title:"Engine Tuner",icon:"√¢¬ö¬ô√Ø¬∏¬è"},
  {xp:5800,title:"Power Wielder",icon:"√¢¬ö¬°"},
