    if(unlocked){
      html+=`<div class="story-card" onclick="this.querySelector('.story-body').classList.toggle('open')">
        <div class="story-header">√∞¬ü¬ì¬ñ <span style="color:var(--gold)">${s.title}</span></div>
        <div class="story-who">√∞¬ü¬ë¬§ ${s.who}'s Story √Ç¬∑ From Level ${s.levelId}</div>
        <div class="story-body"><p>${s.content}</p>
        <p class="story-lesson">√∞¬ü¬í¬° ${s.lesson}</p></div>
      </div>`;
    } else {
      html+=`<div class="story-card locked">
        <div class="story-header">√∞¬ü¬î¬í <span>Complete Level ${s.levelId} to unlock</span></div>
        <div class="story-who" style="color:var(--locked)">From ${s.zoneName}</div>
