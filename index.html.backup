// ===== MOBILE GESTURES =====
let touchStartX = 0;
let touchStartY = 0;
let touchEndX = 0;
let touchEndY = 0;
const swipeThreshold = 80;
const angleThreshold = 30;

function handleSwipe() {
  const deltaX = touchEndX - touchStartX;
  const deltaY = touchEndY - touchStartY;
  const angle = Math.abs(Math.atan2(deltaY, deltaX) * 180 / Math.PI);
  
  if (Math.abs(deltaX) > swipeThreshold && (angle < angleThreshold || angle > 180 - angleThreshold)) {
    if (currentView === 'level' && state.currentLevel) {
      const allLevels = [];
      ZONES.forEach(z => z.levels.forEach(l => allLevels.push(l.id)));
      const idx = allLevels.indexOf(state.currentLevel);
      
      if (deltaX > 0 && idx > 0) {
        const prev = allLevels[idx - 1];
        if (isLevelUnlocked(prev)) {
          playSound('click');
          openLevel(prev);
        }
      } else if (deltaX < 0 && idx < allLevels.length - 1) {
        const next = allLevels[idx + 1];
        if (isLevelUnlocked(next) && isLevelCompleted(state.currentLevel)) {
          playSound('click');
          openLevel(next);
        }
      }
    }
  }
}

document.addEventListener('touchstart', e => {
  touchStartX = e.changedTouches[0].screenX;
  touchStartY = e.changedTouches[0].screenY;
}, false);

document.addEventListener('touchend', e => {
  touchEndX = e.changedTouches[0].screenX;
  touchEndY = e.changedTouches[0].screenY;
  handleSwipe();
}, false);

// ===== IMPROVED TOUCH DRAG & DROP =====
let draggedElement = null;

document.addEventListener('touchstart', e => {
  const target = e.target.closest('.dd-item, .order-item');
  if (target && target.draggable !== false) {
    draggedElement = target;
    target.style.opacity = '0.5';
    target.style.transform = 'scale(1.05)';
  }
}, {passive: true});

document.addEventListener('touchmove', e => {
  if (!draggedElement) return;
  e.preventDefault();
  
  const touch = e.changedTouches[0];
  const elementBelow = document.elementFromPoint(touch.clientX, touch.clientY);
  
  document.querySelectorAll('.dd-target, .order-item').forEach(el => {
    el.classList.remove('over');
  });
  
  const dropZone = elementBelow?.closest('.dd-target, .order-item');
  if (dropZone && dropZone !== draggedElement) {
    dropZone.classList.add('over');
  }
}, {passive: false});

document.addEventListener('touchend', e => {
  if (!draggedElement) return;
  
  draggedElement.style.opacity = '';
  draggedElement.style.transform = '';
  
  const touch = e.changedTouches[0];
  const elementBelow = document.elementFromPoint(touch.clientX, touch.clientY);
  const dropZone = elementBelow?.closest('.dd-target, .order-item');
  
  if (dropZone && dropZone !== draggedElement) {
    if (dropZone.classList.contains('dd-target') && draggedElement.classList.contains('dd-item')) {
      const itemId = draggedElement.dataset.id;
      const targetId = dropZone.dataset.id;
      
      if (!dropZone.querySelector('.dd-item')) {
        dropZone.appendChild(draggedElement);
        draggedElement.classList.add('matched');
        dropZone.classList.add('filled');
        playSound('click');
      }
    }
    else if (dropZone.classList.contains('order-item') && draggedElement.classList.contains('order-item')) {
      const parent = draggedElement.parentNode;
      const draggedIndex = Array.from(parent.children).indexOf(draggedElement);
      const dropIndex = Array.from(parent.children).indexOf(dropZone);
      
      if (draggedIndex < dropIndex) {
        parent.insertBefore(draggedElement, dropZone.nextSibling);
      } else {
        parent.insertBefore(draggedElement, dropZone);
      }
      playSound('click');
    }
  }
  
  document.querySelectorAll('.dd-target, .order-item').forEach(el => {
    el.classList.remove('over');
  });
  
  draggedElement = null;
}, {passive: true});

  } else {
    showView('map');
  }
}

